---
import Base from '@/layouts/Base.astro';
import Button from '@/components/Button.astro';
import Mark from '@/components/Mark.astro';
import Plus from '@/components/Plus.astro';
import FlowLines from '@/components/FlowLines.astro';
import SectionHeader from '@/components/SectionHeader.astro';

const impact = [
  { t: 'Projectdagen voor stichtingen en kerken zonder budget', b: 'Organisaties met echte behoefte krijgen dezelfde curatie en kalibrering als betaalde opdrachten.' },
  { t: 'Het bouwen van een eigen locatie', b: 'Een plek waar diep werk gewoon kan plaatsvinden. Zie onze visie.' },
  { t: 'Reisbeurzen voor internationale bouwers', b: 'Zodat de juiste mensen aan tafel kunnen zitten, ongeacht waar ze wonen.' },
  { t: 'Open source projecten uit de community', b: 'Werk dat ten goede komt van iedereen die het kan gebruiken.' },
];

const tiers = [
  { name: 'Friend', intent: 'Jaarlijkse bijdrage.', perks: ['Je naam in onze jaarrapportage', 'Toegang tot het jaarlijkse partner-diner'], hero: false },
  { name: 'Builder', intent: 'Substantiële bijdrage.', perks: ['Betrokken bij de richting', 'Optionele zichtbaarheid', 'Uitnodiging voor twee gatherings per jaar'], hero: true },
  { name: 'Patron', intent: 'Principal-level steun.', perks: ['Persoonlijk gesprek en partnerschap', 'Co-naam op een initiatief naar keuze'], hero: false },
];

const breakdown = [
  { num: '60%', label: 'Project funding voor opdrachten zonder budget' },
  { num: '25%', label: 'Operations (locatie, organisatie, reiskosten)' },
  { num: '15%', label: 'Groei (uitbreiding van community, open source)' },
];
---
<Base title="Support CTF — Christian Tech Founders" current="support">
  <section class="ctf-shell" style="padding-top:24px;">
    <div class="ctf-card hero-support">
      <FlowLines intensity={0.4} />
      <div class="hero-inner">
        <span class="ctf-eyebrow-row fx-rise" style="justify-content:center;margin-bottom:32px;">Voor partners</span>
        <h1 class="hero-title fx-rise-lg">
          Maak mogelijk dat<br />
          de juiste mensen<br />
          <Mark>samen bouwen</Mark>.
        </h1>
        <p class="hero-lede fx-rise">
          CTF blijft bewust klein en gecureerd. Steun bepaalt of we groeien op de manier die we willen.
        </p>
        <div class="hero-cta fx-rise">
          <Button variant="primary" href="/partner" magnet>Word partner</Button>
          <Button variant="outline" href="/vision">Lees onze visie</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="why-grid" data-reveal>
        <div>
          <span class="ctf-eyebrow-row" style="margin-bottom:24px;">Waarom</span>
          <h2 class="t-display-md">Waarom CTF steun nodig heeft.</h2>
        </div>
        <div class="ctf-paper why-prose">
          <p style="font: var(--t-serif-body-lg); color: var(--ink-1);"><Plus letter="C" />TF is geen agency. De community is gratis voor bouwers.</p>
          <p style="font: var(--t-serif-body-lg); color: var(--ink-2);"><Plus letter="P" />roject-intake van bedrijven dekt een deel van wat we doen. Het deel dat CTF bijzonder maakt, zorgvuldige curatie, projectdagen voor projecten zonder budget, ooit een eigen locatie, draait niet zonder partners.</p>
          <p style="font: var(--t-serif-body-lg); color: var(--ink-2);"><Plus letter="W" />e willen niet groeien door schaal. We willen groeien door diepte. Partners maken dat mogelijk.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="ctf-wrap">
        <SectionHeader eyebrow="Impact" title="Wat jouw steun mogelijk maakt." />
        <div class="impact-grid" data-tilt="4">
          {impact.map((c) => (
            <div class="ctf-paper impact-card" data-reveal>
              <h3 class="impact-title">{c.t}</h3>
              <p class="impact-body">{c.b}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="ctf-wrap">
        <SectionHeader eyebrow="Tiers" title="Drie manieren om bij te dragen." />
        <div class="tier-grid">
          {tiers.map((tier) => (
            <div class={`ctf-tier ${tier.hero ? 'ctf-tier-hero' : ''}`} data-reveal>
              {tier.hero && <span class="ctf-tier-badge">Meest gekozen</span>}
              <div>
                <h3 class="tier-name">{tier.name}.</h3>
                <p class="tier-intent">{tier.intent}</p>
              </div>
              <div class="tier-perks">
                {tier.perks.map((p) => (
                  <div class="tier-perk">
                    <span style="color: var(--ctf-blue);">+</span>
                    <span>{p}</span>
                  </div>
                ))}
              </div>
              <Button variant={tier.hero ? 'primary' : 'outline'} href="/partner" magnet={tier.hero}>Word {tier.name.toLowerCase()}</Button>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="ctf-wrap">
        <SectionHeader eyebrow="Transparantie" title="Waar gaat het naartoe." />
        <div class="pct-grid">
          {breakdown.map((b) => (
            <div class="ctf-pct" data-reveal>
              <div class="ctf-pct-num" style="margin-bottom:20px;">{b.num}</div>
              <p style="font: var(--t-serif-body); color: var(--ink-2);">{b.label}</p>
            </div>
          ))}
        </div>
        <p class="transparency-note">We publiceren jaarlijks een transparant rapport van uitgaven en projecten.</p>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="ctf-wrap">
        <SectionHeader eyebrow="Onze partners" title="Onze huidige partners." />
        <div class="logos">
          {Array.from({ length: 6 }).map((_, i) => (
            <div class="logo-box" data-reveal>Partner {i + 1}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section style="margin:24px;">
    <div class="ctf-card-dark closing-dark" data-reveal>
      <h2 class="closing-dark-title">Wil je dit mogelijk maken?</h2>
      <p class="closing-dark-lede">Een gesprek is de eerste stap. We sturen geen pitchdeck.</p>
      <div style="margin-top:36px;">
        <Button variant="onDark" href="/partner" magnet>Word partner</Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-support { padding: 160px 80px 96px; position: relative; overflow: hidden; }
  .hero-inner { position: relative; max-width: 980px; margin: 0 auto; text-align: center; }
  .hero-title { font: var(--t-display-xl); letter-spacing: -0.025em; line-height: 1.02; color: var(--ink-1); }
  .hero-lede { margin: 36px auto 0; max-width: 560px; font: var(--t-serif-body-lg); color: var(--ink-3); }
  .hero-cta { margin-top: 40px; display: inline-flex; align-items: center; gap: 14px; flex-wrap: wrap; justify-content: center; }

  .sec-pad { padding: 96px 80px; }
  .ctf-wrap { max-width: 1200px; margin: 0 auto; }
  .t-display-md { font: var(--t-display-md); color: var(--ink-1); letter-spacing: -0.025em; }

  .why-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px; align-items: start; }
  .why-prose { padding: 40px; display: grid; gap: 24px; }

  .impact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 56px; }
  .impact-card { padding: 36px; }
  .impact-title { font: var(--t-h3); color: var(--ink-1); letter-spacing: -0.02em; margin-bottom: 16px; }
  .impact-body { font: var(--t-serif-body); color: var(--ink-2); }

  .tier-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 64px; align-items: stretch; }
  .tier-name { font: var(--t-display-sm); color: var(--ink-1); letter-spacing: -0.025em; margin-bottom: 8px; }
  .tier-intent { font: var(--t-serif-body); color: var(--ink-3); }
  .tier-perks { margin-top: auto; display: grid; gap: 14px; }
  .tier-perk { display: flex; gap: 12px; font: var(--t-serif-body); color: var(--ink-2); border-top: 1px solid var(--line-1); padding-top: 14px; }

  .pct-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 56px; }
  .transparency-note { margin-top: 32px; font: var(--t-serif-body-sm); color: var(--ink-3); max-width: 560px; }

  .logos { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 56px; }
  .logo-box { padding: 48px; border: 1px solid var(--line-1); border-radius: var(--r-md); text-align: center; font: var(--t-label); color: var(--ink-3); background: var(--bg-paper); }

  .closing-dark { padding: 120px 64px; text-align: center; }
  .closing-dark-title { font: var(--t-display-lg); color: var(--ink-on-dark-1); letter-spacing: -0.025em; line-height: 1.05; max-width: 720px; margin: 0 auto; }
  .closing-dark-lede { margin: 24px auto 0; font: var(--t-serif-body-lg); color: var(--ink-on-dark-2); max-width: 460px; }

  @media (max-width: 1000px) {
    .hero-support { padding: 96px 32px 64px; }
    .sec-pad { padding: 72px 32px; }
    .why-grid, .impact-grid, .tier-grid, .pct-grid, .logos { grid-template-columns: 1fr; gap: 24px; }
    .closing-dark { padding: 72px 32px; }
  }
</style>
