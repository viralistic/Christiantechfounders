---
import Base from '@/layouts/Base.astro';
import Button from '@/components/Button.astro';

const budgets = ['< 5000', '5000 - 15000', '15000 - 30000', '30000+', 'weet ik niet'];
---
<Base title="Dien je project in — CTF" current="projects" hideFooter={true}>
  <section class="ctf-shell" style="padding-top:24px;">
    <div class="ctf-card form-card">
      <div class="form-wrap">
        <div class="form-back fx-rise"><a href="/"><span>←</span>Terug</a></div>
        <span class="ctf-eyebrow-row fx-rise" style="margin-bottom:20px;">Dien je project in</span>
        <h1 class="form-title fx-rise-lg">Dien je project in.</h1>
        <p class="form-sub fx-rise">Vertel ons wat het vraagstuk is. Niet wat de oplossing moet zijn.</p>

        <form id="project-form" action="#" class="form" data-reveal>
          <label class="field"><span class="label">Organisatie</span><input type="text" required /></label>
          <label class="field"><span class="label">Naam contactpersoon</span><input type="text" required /></label>
          <label class="field"><span class="label">E-mail</span><input type="email" required /></label>
          <label class="field"><span class="label">Telefoon</span><span class="hint">Optioneel</span><input type="tel" /></label>
          <label class="field">
            <span class="label">Wat is je vraagstuk?</span>
            <span class="hint">Beschrijf het probleem, niet de gewenste oplossing.</span>
            <textarea required></textarea>
          </label>
          <label class="field"><span class="label">Welke deadline is er?</span><input type="text" /></label>
          <div class="field">
            <span class="label">Wat is je budget-indicatie?</span>
            <div class="radio-stack">
              {budgets.map((v) => (
                <label class="radio">
                  <input type="radio" name="budget" value={v} />
                  <span>{v === 'weet ik niet' ? 'Weet ik niet' : `€ ${v}`}</span>
                </label>
              ))}
            </div>
          </div>
          <div class="form-actions">
            <Button variant="primary" magnet>Verstuur vraagstuk</Button>
            <span class="footnote">We laten binnen een week weten of het past.</span>
          </div>
        </form>

        <div id="project-thanks" class="thanks" hidden>
          <span class="ctf-eyebrow-row" style="justify-content:center; color:var(--ctf-blue); margin-bottom:12px;">Verstuurd</span>
          <h2>Dankjewel.</h2>
          <p>We laten binnen een week weten of het past.</p>
          <div style="margin-top:32px;"><Button variant="outline" href="/">Naar de homepage</Button></div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .form-card { padding: 96px 80px; }
  .form-wrap { max-width: 560px; margin: 0 auto; }
  .form-back a { color: var(--ink-3); font: var(--t-body-sm); display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
  .form-back { margin-bottom: 40px; }
  .form-title { font: var(--t-display-sm); letter-spacing: -0.025em; color: var(--ink-1); line-height: 1.1; }
  .form-sub { margin-top: 20px; font: var(--t-serif-body-lg); color: var(--ink-2); }
  .form { margin-top: 48px; display: grid; gap: 28px; }
  .field { display: grid; gap: 8px; }
  .label { font: var(--t-label); color: var(--ink-1); }
  .hint { font: var(--t-body-sm); color: var(--ink-3); }
  .field input, .field textarea { width: 100%; padding: 14px 18px; background: var(--bg-paper); border: 1px solid var(--line-1); border-radius: var(--r-md); font: var(--t-body); color: var(--ink-1); outline: none; font-family: var(--font-ui); }
  .field textarea { min-height: 120px; resize: vertical; }
  .radio-stack { display: grid; gap: 8px; }
  .radio { display: flex; align-items: center; gap: 12px; padding: 14px 18px; background: var(--bg-paper); border: 1px solid var(--line-1); border-radius: var(--r-md); cursor: pointer; font: var(--t-body); color: var(--ink-1); transition: all 180ms ease; }
  .radio:has(input:checked) { background: rgba(0,0,255,0.04); border-color: var(--ctf-blue); }
  .radio input { accent-color: var(--ctf-blue); }
  .form-actions { display: grid; gap: 12px; margin-top: 8px; }
  .footnote { font: var(--t-body-sm); color: var(--ink-3); }
  .thanks { margin-top: 48px; padding: 40px; background: var(--bg-paper); border-radius: var(--r-lg); border: 1px solid var(--line-1); text-align: center; }
  .thanks h2 { font: var(--t-h2); color: var(--ink-1); letter-spacing: -0.02em; margin-bottom: 16px; }
  .thanks p { font: var(--t-serif-body); color: var(--ink-2); }

  @media (max-width: 1000px) { .form-card { padding: 72px 24px; } }
</style>

<script>
  const form = document.getElementById('project-form') as HTMLFormElement | null;
  const thanks = document.getElementById('project-thanks');
  form?.addEventListener('submit', (e) => { e.preventDefault(); form.hidden = true; if (thanks) thanks.hidden = false; window.scrollTo({ top: 0, behavior: 'smooth' }); });
</script>
