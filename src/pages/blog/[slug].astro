---
import Base from '@/layouts/Base.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { POSTS, type Post } from '@/data/posts';
export function getStaticPaths() {
  return POSTS.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props as { post: Post };

// Related posts: other 3
const related = POSTS.filter((p) => p.slug !== post.slug).slice(0, 3);
---
<Base title={`${post.title} — CTF`} current="blog">
  <!-- HERO with breadcrumbs -->
  <section class="ctf-shell" style="padding-top:24px;">
    <div class="ctf-card post-hero">
      <nav class="crumbs fx-fade" aria-label="Breadcrumbs">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <a href="/blog">Schrijven</a>
        <span class="sep">/</span>
        <span class="crumb-current">{post.category}</span>
      </nav>

      <div class="post-head">
        <span class={`cat-chip cat-${post.category.toLowerCase()} fx-rise`}>{post.category}</span>
        <span class="ctf-eyebrow-row fx-rise" style="margin: 16px 0;">{post.date}</span>
        <h1 class="post-title fx-rise-lg">{post.title}</h1>
        <p class="post-lede fx-rise">{post.lede}</p>

        <div class="author-row fx-rise">
          <div class="ctf-avatar" style="width:44px; height:44px; font-size:16px;">{post.authorInit}</div>
          <div>
            <div class="author-name">{post.author}</div>
            <div class="author-meta">{post.authorRole} · {post.read}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLE + STICKY TOC -->
  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card post-body">
      <div class="post-grid">
        <aside class="toc" aria-label="Inhoud">
          <div class="toc-sticky">
            <span class="ctf-eyebrow-row" style="margin-bottom:16px;">Inhoud</span>
            <ol class="toc-list" id="toc-list">
              {post.sections.map((s, i) => (
                <li>
                  <a href={`#${s.id}`} data-toc-link={s.id}>
                    <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
                    <span class="toc-label">{s.heading.replace(/\.$/, '')}</span>
                  </a>
                </li>
              ))}
            </ol>
            <div class="toc-progress" aria-hidden="true">
              <div class="toc-progress-bar" id="toc-progress-bar"></div>
            </div>
          </div>
        </aside>

        <article class="article" data-reveal>
          {post.sections.map((s) => (
            <section id={s.id} class="article-section">
              <h2 class="article-h2">{s.heading}</h2>
              {s.paragraphs.map((p) => {
                if (typeof p === 'string') return <p>{p}</p>;
                if ('quote' in p) return <blockquote>"{p.quote}"</blockquote>;
                if ('pull' in p) return <p class="pull-quote">{p.pull}</p>;
                return null;
              })}
            </section>
          ))}

          <footer class="article-foot">
            <div class="written">
              Geschreven door {post.author}, {post.date}.
            </div>
            <div class="tag-row">
              {post.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </footer>
        </article>
      </div>
    </div>
  </section>

  <!-- MORE -->
  <section class="ctf-shell" style="margin-top:24px; margin-bottom:24px;">
    <div class="ctf-card sec-pad">
      <div class="ctf-wrap">
        <SectionHeader eyebrow="Meer lezen" title="Meer lezen." />
        <div class="more-grid">
          {related.map((p) => (
            <a class="more-card fx-card-hover" href={`/blog/${p.slug}`} data-reveal>
              <span class={`cat-chip cat-${p.category.toLowerCase()}`}>{p.category}</span>
              <span class="ctf-eyebrow-row" style="margin: 12px 0;">{p.date}</span>
              <h4 class="more-title">{p.title}</h4>
              <p class="more-excerpt">{p.lede}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  function wireTOC() {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    const sections = Array.from(links)
      .map((l) => document.getElementById(l.dataset.tocLink!))
      .filter((el): el is HTMLElement => !!el);
    const progressBar = document.getElementById('toc-progress-bar');
    if (!links.length || !sections.length) return;

    const setActive = (id: string) => {
      links.forEach((l) =>
        l.classList.toggle('active', l.dataset.tocLink === id),
      );
    };

    // Smooth scroll
    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = link.dataset.tocLink!;
        const target = document.getElementById(id);
        if (!target) return;
        const top = target.getBoundingClientRect().top + window.scrollY - 110;
        window.scrollTo({ top, behavior: 'smooth' });
        history.replaceState(null, '', `#${id}`);
      });
    });

    // Scroll-spy + progress
    const onScroll = () => {
      const probe = window.scrollY + 200;
      let activeId = sections[0].id;
      for (const sec of sections) {
        if (sec.offsetTop <= probe) activeId = sec.id;
      }
      setActive(activeId);

      const article = document.querySelector('.article') as HTMLElement | null;
      if (article && progressBar) {
        const rect = article.getBoundingClientRect();
        const total = article.offsetHeight - window.innerHeight;
        const passed = -rect.top;
        const pct = Math.max(0, Math.min(1, passed / total));
        progressBar.style.transform = `scaleY(${pct})`;
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
  wireTOC();
  document.addEventListener('astro:page-load', wireTOC);
</script>

<style>
  /* HERO */
  .post-hero { padding: 120px 80px 80px; }
  .crumbs {
    max-width: 1200px; margin: 0 auto 48px;
    font: var(--t-body-sm); color: var(--ink-3);
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .crumbs a { color: var(--ink-3); text-decoration: none; transition: color 180ms; }
  .crumbs a:hover { color: var(--ctf-blue); }
  .crumbs .sep { color: var(--ink-5); }
  .crumbs .crumb-current { color: var(--ink-1); }

  .post-head { max-width: 760px; margin: 0 auto; }
  .post-title {
    font: var(--t-display-md);
    letter-spacing: -0.025em; line-height: 1.08;
    color: var(--ink-1);
  }
  .post-lede {
    margin-top: 24px;
    font: var(--t-serif-body-lg);
    color: var(--ink-3);
  }
  .author-row {
    margin-top: 40px; padding-top: 24px;
    border-top: 1px solid var(--line-1);
    display: flex; gap: 16px; align-items: center;
  }
  .author-name { font: var(--t-label); color: var(--ink-1); }
  .author-meta { font: var(--t-caption); color: var(--ink-3); }

  .cat-chip {
    display: inline-flex; align-items: center;
    padding: 5px 12px;
    background: rgba(0,0,255,0.08); color: var(--ctf-blue);
    font: var(--t-eyebrow);
    text-transform: uppercase; letter-spacing: 0.08em;
    border-radius: var(--r-pill);
    width: max-content;
  }
  .cat-launch    { background: rgba(0,0,255,0.10); color: var(--ctf-blue); }
  .cat-community { background: rgba(30,30,30,0.08); color: var(--ink-1); }
  .cat-news      { background: rgba(218, 88, 0, 0.10); color: #c25216; }
  .cat-essays    { background: rgba(0,80,0,0.08); color: #1f5a2f; }
  .cat-reflecties{ background: rgba(122, 123, 255, 0.18); color: #4243c7; }

  /* BODY */
  /* `position: sticky` breaks inside any ancestor with `overflow: hidden`
     (the global .ctf-card sets it). We override to `visible` here — this
     card has no FlowLines or dots overlay to clip, so it's safe. */
  .ctf-card.post-body { padding: 96px 80px; overflow: visible !important; }
  .post-grid {
    max-width: 1200px; margin: 0 auto;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 80px;
    /* No `align-items: start` — the TOC column must stretch to the article's
       height so the sticky child has room to slide within it. */
  }

  /* TOC */
  .toc { position: relative; }
  .toc-sticky {
    position: sticky; top: 110px;
    display: flex; flex-direction: column; gap: 8px;
    padding-right: 16px;
    border-right: 1px solid var(--line-1);
  }
  .toc-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 4px;
    counter-reset: toc;
  }
  .toc-list a {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 10px;
    padding: 10px 12px 10px 4px;
    font: var(--t-body-sm);
    color: var(--ink-4);
    text-decoration: none;
    border-radius: var(--r-sm);
    transition: color 220ms var(--easing), background 220ms var(--easing), transform 220ms var(--easing);
  }
  .toc-list a:hover { color: var(--ink-1); background: rgba(10,10,11,0.03); }
  .toc-num {
    font-family: var(--font-display);
    font-size: 13px;
    color: var(--ink-5);
    transition: color 220ms var(--easing);
  }
  .toc-label {
    line-height: 1.4;
    letter-spacing: 0;
  }
  .toc-list a.active {
    color: var(--ink-1);
    background: rgba(0,0,255,0.04);
    transform: translateX(2px);
  }
  .toc-list a.active .toc-num { color: var(--ctf-blue); }

  .toc-progress {
    margin-top: 20px;
    width: 2px; height: 64px;
    background: var(--line-1);
    border-radius: 2px; overflow: hidden;
    position: relative;
  }
  .toc-progress-bar {
    position: absolute; inset: 0;
    background: var(--ctf-blue);
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 120ms linear;
  }

  /* ARTICLE */
  .article {
    max-width: 680px;
    font-family: var(--font-ui);
    font-size: 17px; line-height: 1.7;
    color: var(--ink-2);
  }
  .article-section { margin-bottom: 48px; scroll-margin-top: 110px; }
  .article-section:last-of-type { margin-bottom: 0; }
  .article p { margin-bottom: 22px; }
  .article-h2 {
    font-family: var(--font-display); font-weight: 400;
    font-size: 32px; line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--ink-1);
    margin: 0 0 20px;
  }
  .article blockquote {
    border-left: 2px solid var(--ctf-blue);
    padding: 4px 0 4px 22px;
    margin: 28px 0;
    font-style: italic;
    font-family: var(--font-text);
    font-size: 19px; line-height: 1.55;
    color: var(--ink-1);
  }
  .article .pull-quote {
    font-family: var(--font-headline); font-style: italic;
    font-size: 26px; line-height: 1.4;
    max-width: 540px; margin: 48px auto;
    text-align: center;
    color: var(--ink-1);
    padding: 32px 0;
    border-top: 1px solid var(--line-1);
    border-bottom: 1px solid var(--line-1);
  }

  /* Article footer */
  .article-foot {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--line-1);
  }
  .written { font: var(--t-body); color: var(--ink-2); margin-bottom: 20px; }
  .tag-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .tag {
    padding: 6px 14px;
    border: 1px solid var(--line-1);
    border-radius: var(--r-pill);
    font: var(--t-caption);
    color: var(--ink-2);
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  /* More */
  .sec-pad { padding: 96px 80px; }
  .ctf-wrap { max-width: 1200px; margin: 0 auto; }
  .more-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 56px; }
  .more-card {
    text-decoration: none; color: inherit;
    display: block; padding: 24px;
    border: 1px solid var(--line-1);
    border-radius: var(--r-lg);
    background: var(--bg-paper);
  }
  .more-title { font: var(--t-h3); color: var(--ink-1); letter-spacing: -0.02em; margin: 0 0 12px; }
  .more-excerpt { font: var(--t-serif-body-sm); color: var(--ink-3); }

  /* Mobile */
  @media (max-width: 1000px) {
    .post-hero { padding: 96px 32px 56px; }
    .post-body { padding: 56px 32px; }
    .crumbs { margin: 0 auto 32px; }
    .post-grid { grid-template-columns: 1fr; gap: 32px; }
    .toc-sticky {
      position: static;
      border-right: 0;
      border-top: 1px solid var(--line-1);
      border-bottom: 1px solid var(--line-1);
      padding: 20px 0;
    }
    .toc-progress { display: none; }
    .sec-pad { padding: 56px 32px; }
    .more-grid { grid-template-columns: 1fr; }
    .article-h2 { font-size: 26px; }
    .article .pull-quote { font-size: 20px; }
  }
</style>
