---
import Base from '@/layouts/Base.astro';
import Button from '@/components/Button.astro';
import Mark from '@/components/Mark.astro';
import Plus from '@/components/Plus.astro';
import FlowLines from '@/components/FlowLines.astro';
import SectionHeader from '@/components/SectionHeader.astro';

export function getStaticPaths() {
  return [{ params: { slug: 'example' } }];
}

const meta = [
  { k: 'Opdrachtgever', v: 'Stichting Jeugdwerk Fryslân' },
  { k: 'Datum', v: 'Maart 2026' },
  { k: 'Team', v: '5 bouwers' },
  { k: 'Type', v: 'Projectdag' },
];

const team = [
  { name: 'Mark Visser', role: 'Lead bouwer', init: 'MV' },
  { name: 'Sanne de Wit', role: 'Product', init: 'SW' },
  { name: 'Daan Pieters', role: 'Backend', init: 'DP' },
  { name: 'Esther Vos', role: 'Frontend', init: 'EV' },
  { name: 'Bram de Jong', role: 'Strategie', init: 'BJ' },
];

const deliverables = [
  'Een werkend MVP gehost op Netlify',
  'Documentatie voor de stichting',
  'Een onderhoudsplan voor de komende 12 maanden',
];

const similar = [
  { id: 'p01', num: '01', title: 'Een platform voor jongerenwerk in kleine kerken', tag: 'Stichting' },
  { id: 'p02', num: '02', title: 'Ethisch raamwerk voor intern LLM-gebruik', tag: 'Commercieel' },
  { id: 'p03', num: '03', title: 'Researchtool voor academici, MVP', tag: 'Community' },
];
---
<Base title="Project — Christian Tech Founders" current="projects">
  <section class="ctf-shell" style="padding-top:24px;">
    <div class="ctf-card hero-detail">
      <FlowLines intensity={0.35} />
      <div class="hero-inner">
        <div class="crumb fx-rise">
          <a href="/projects">Projecten</a>
          <span style="margin:0 8px; color: var(--ink-5);">/</span>
          <span>Jongerenwerk in kleine kerken</span>
        </div>
        <span class="ctf-eyebrow-row fx-rise" style="margin-bottom:28px; color:var(--ctf-blue);">Stichting</span>
        <h1 class="hero-title fx-rise-lg">Een platform voor <Mark>jongerenwerk</Mark> in kleine kerken.</h1>
        <p class="hero-lede fx-rise">
          Een stichting in Friesland had een vraagstuk over hoe vrijwilligers in kleine kerken hun jeugdwerk kunnen organiseren zonder dure software. We zochten een oplossing die zonder budget kan blijven draaien.
        </p>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card" style="padding:48px 80px;">
      <div class="meta-grid" data-reveal>
        {meta.map((m) => (
          <div>
            <span class="ctf-eyebrow-row" style="margin-bottom:10px;">{m.k}</span>
            <div class="meta-val">{m.v}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="split-grid" data-reveal>
        <div>
          <span class="ctf-eyebrow-row" style="margin-bottom:24px;">Het vraagstuk</span>
          <h2 class="t-display-md">Het vraagstuk.</h2>
        </div>
        <div class="ctf-prose">
          <p><Plus letter="V" />rijwilligers in kleine kerken doen veel ad-hoc, in WhatsApp-groepen en losse spreadsheets. Wanneer ze willen samenwerken over kerken heen, valt het hele systeem uit elkaar.</p>
          <p><Plus letter="C" />ommerciële tools voor jeugdwerk bestaan, maar kosten 200 tot 500 euro per jaar per kerk. Voor een netwerk van twintig kleine kerken loopt dat snel op.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="split-grid" data-reveal>
        <div>
          <span class="ctf-eyebrow-row" style="margin-bottom:24px;">De aanpak</span>
          <h2 class="t-display-md">Hoe we het hebben aangepakt.</h2>
        </div>
        <div class="ctf-prose">
          <p><Plus letter="O" />chtend: probleem ontleden met twee vertegenwoordigers van de stichting en vijf bouwers. We kwamen erachter dat het echte vraagstuk niet "een tool" was, maar "hoe houden we het simpel genoeg dat een vrijwilliger het kan onderhouden".</p>
          <p><Plus letter="M" />iddag: drie subgroepen. Een groep bouwde een minimaal MVP in Next.js + Supabase. Een groep schreef de hosting-strategie zodat het zonder maandelijkse kosten kan blijven draaien. Een groep maakte een onderhoudsplan en documentatie voor de stichting.</p>
          <p><Plus letter="A" />vond: demo aan de stichting, twee aanpassingen meteen doorgevoerd, oplevering inclusief code en documentatie.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="ctf-wrap">
        <SectionHeader eyebrow="Het team" title="Het team." />
        <div class="team-grid">
          {team.map((p) => (
            <div class="team-member" data-reveal>
              <div class="ctf-avatar" style="margin:0 auto 16px; width:80px; height:80px; font-size:28px;">{p.init}</div>
              <div class="team-name">{p.name}</div>
              <div class="team-role">{p.role}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="split-grid" data-reveal>
        <div>
          <span class="ctf-eyebrow-row" style="margin-bottom:24px;">Uitkomst</span>
          <h2 class="t-display-md">Wat we hebben opgeleverd.</h2>
        </div>
        <div>
          <div class="ctf-prose" style="gap:20px;">
            <p>Een werkend platform, gehost zonder maandelijkse kosten, met documentatie en een onderhoudsplan zodat de stichting het zelf kan beheren.</p>
            <p>De stichting gebruikt het platform sinds april 2026 in zes kerken. Drie andere kerken zijn aangesloten in de loop van het jaar.</p>
          </div>
          <div style="margin-top:40px;">
            <span class="ctf-eyebrow-row" style="margin-bottom:16px;">Deliverables</span>
            {deliverables.map((d) => (
              <div class="deliverable"><Plus />{d}</div>
            ))}
            <div style="border-top:1px solid var(--line-1);"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card" style="padding:120px 80px;">
      <div class="quote-wrap" data-reveal>
        <p class="quote-text">"Dit was geen pitchclub of brainstorm. We gingen met een vraag de dag in en met iets werkends de dag uit."</p>
        <div class="quote-attr">Janneke de Boer · Voorzitter · Stichting Jeugdwerk Fryslân</div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px;">
    <div class="ctf-card sec-pad">
      <div class="ctf-wrap">
        <SectionHeader eyebrow="Vergelijkbaar" title="Vergelijkbare projecten." />
        <div class="similar-grid">
          {similar.map((p) => (
            <a class="similar-card" href="/projects/example" data-reveal>
              <div class="similar-art">
                <span class="ctf-eyebrow-row on-dark">Project {p.num}</span>
                <h3 class="similar-title">{p.title}</h3>
              </div>
              <span class="ctf-eyebrow-row" style="color:var(--ctf-blue);">{p.tag}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="ctf-shell" style="margin-top:24px; margin-bottom:24px;">
    <div class="ctf-card sec-pad">
      <div class="closing-inner" data-reveal>
        <h3 class="t-display-md">Heb je zelf een vraagstuk?</h3>
        <div style="margin-top:32px;">
          <Button variant="primary" href="/submit-project" magnet>Dien je project in</Button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-detail { padding: 120px 80px 80px; position: relative; overflow: hidden; }
  .hero-inner { position: relative; max-width: 1100px; margin: 0 auto; }
  .crumb { font: var(--t-body-sm); color: var(--ink-3); margin-bottom: 24px; }
  .crumb a { color: var(--ink-3); text-decoration: none; }
  .hero-title { font: var(--t-display-lg); letter-spacing: -0.025em; line-height: 1.05; color: var(--ink-1); max-width: 1000px; }
  .hero-lede { margin-top: 32px; font: var(--t-serif-body-lg); color: var(--ink-2); max-width: 580px; }

  .meta-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .meta-val { font: var(--t-h4); color: var(--ink-1); letter-spacing: -0.02em; }

  .sec-pad { padding: 96px 80px; }
  .split-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px; align-items: start; }
  .t-display-md { font: var(--t-display-md); letter-spacing: -0.025em; color: var(--ink-1); }
  .ctf-wrap { max-width: 1200px; margin: 0 auto; }

  .team-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 24px; margin-top: 56px; }
  .team-member { text-align: center; }
  .team-name { font: var(--t-label); color: var(--ink-1); margin-bottom: 4px; }
  .team-role { font: var(--t-caption); color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; }

  .deliverable { padding: 16px 0; border-top: 1px solid var(--line-1); font: var(--t-serif-body-lg); color: var(--ink-1); }

  .quote-wrap { max-width: 760px; margin: 0 auto; text-align: center; }
  .quote-text { font-family: var(--font-headline); font-style: italic; font-size: clamp(28px, 4vw, 40px); line-height: 1.3; color: var(--ink-1); letter-spacing: -0.015em; }
  .quote-attr { margin-top: 32px; font: var(--t-label); color: var(--ink-3); }

  .similar-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 56px; }
  .similar-card { display: flex; flex-direction: column; gap: 16px; text-decoration: none; color: inherit; }
  .similar-art { aspect-ratio: 4/5; border-radius: var(--r-lg); background: linear-gradient(180deg, #1a1a1c 0%, #0e0e10 100%); padding: 24px; display: flex; flex-direction: column; justify-content: space-between; }
  .ctf-eyebrow-row.on-dark { color: var(--ink-on-dark-3); }
  .similar-title { font: var(--t-h3); color: var(--ink-on-dark-1); letter-spacing: -0.02em; }

  .closing-inner { max-width: 760px; margin: 0 auto; text-align: center; }

  @media (max-width: 1000px) {
    .hero-detail { padding: 80px 32px 56px; }
    .sec-pad { padding: 72px 32px; }
    .meta-grid { grid-template-columns: 1fr 1fr; }
    .split-grid { grid-template-columns: 1fr; gap: 40px; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .similar-grid { grid-template-columns: 1fr; }
  }
</style>
