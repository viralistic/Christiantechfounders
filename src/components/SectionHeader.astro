---
export interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
  align?: 'left' | 'center';
  maxWidth?: number;
}
const { eyebrow, title, lede, align = 'left', maxWidth = 760 } = Astro.props;
const wrapStyle = [
  `max-width:${maxWidth}px;`,
  align === 'center' ? 'margin:0 auto;text-align:center;' : '',
].join('');
---
<div class="sh-wrap" style={wrapStyle}>
  {eyebrow && (
    <span class="ctf-eyebrow-row fx-rise" style={align === 'center' ? 'justify-self:center;' : ''}>
      {eyebrow}
    </span>
  )}
  {title && <h2 class="sh-title fx-rise-lg">{title}</h2>}
  {lede && <p class="sh-lede fx-rise">{lede}</p>}
</div>

<style>
  .sh-wrap { display: grid; gap: 20px; }
  .sh-title {
    font: var(--t-display-md);
    color: var(--ink-1);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .sh-lede {
    font: var(--t-serif-body-lg);
    color: var(--ink-2);
    max-width: 640px;
  }
</style>
