---
export interface Props {
  name: string;
  color?: string;
  delay?: number;
  anchor?: 'tl' | 'tr' | 'bl' | 'br';
  /** any inline positioning, e.g. "top:40px;left:20%;" */
  at?: string;
}
const {
  name,
  color = 'var(--ink-1)',
  delay = 0,
  anchor = 'tl',
  at = '',
} = Astro.props;

const radii: Record<string, string> = {
  bl: '10px 10px 10px 2px',
  br: '10px 10px 2px 10px',
  tl: '2px 10px 10px 10px',
  tr: '10px 2px 10px 10px',
};
const wrapStyle = `${at}; animation: cursorIn 420ms cubic-bezier(0.16,1,0.3,1) ${delay}ms both;`;
const pillStyle = `border-radius:${radii[anchor]};background:${color};`;
---
<div class="cursor-wrap" style={wrapStyle} aria-hidden="true">
  <svg width="18" height="22" viewBox="0 0 14 16" class="cursor-svg">
    <path d="M0 0 L0 14 L4 10 L7 16 L9 15 L6 9 L12 9 Z" fill={color} />
  </svg>
  <span class="cursor-pill" style={pillStyle}>{name}</span>
</div>

<style>
  .cursor-wrap {
    position: absolute;
    display: inline-flex; align-items: flex-start; gap: 4px;
    pointer-events: none; z-index: 5;
  }
  .cursor-svg { display: block; flex: 0 0 18px; }
  .cursor-pill {
    font: var(--t-button);
    padding: 6px 12px;
    color: #fff;
    white-space: nowrap;
    margin-top: 12px;
  }
  @keyframes cursorIn {
    from { opacity: 0; transform: translate(-6px, 6px); }
    to   { opacity: 1; transform: translate(0, 0); }
  }
</style>
