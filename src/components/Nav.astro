---
import Button from './Button.astro';

export interface Props { current?: string }
const { current = '' } = Astro.props;

const overActive  = ['about', 'vision'].includes(current);
const projActive  = current === 'projects' || current === 'projectDetail';
---
<div class="nav-shell">
  <div class="nav-pill">
    <a href="/" class="nav-brand" aria-label="Home">
      <img src="/assets/icon-black.svg" alt="" width="22" height="22" />
      <span>CTF</span>
    </a>

    <nav class="nav-links" aria-label="Hoofdnavigatie">
      <div class="nav-dd">
        <button
          class="nav-link"
          aria-current={overActive ? 'page' : undefined}
          aria-haspopup="true"
          type="button"
        >
          Over
        </button>
        <div class="nav-dd-panel" role="menu">
          <a href="/about" class="nav-dd-item">
            <span class="nav-dd-label">About</span>
            <span class="nav-dd-hint">Wie we zijn</span>
          </a>
          <a href="/vision" class="nav-dd-item">
            <span class="nav-dd-label">Vision</span>
            <span class="nav-dd-hint">Onze missie</span>
          </a>
        </div>
      </div>

      <a
        href="/projects"
        class="nav-link"
        aria-current={projActive ? 'page' : undefined}
      >
        Projecten
      </a>
    </nav>

    <Button href="/apply" magnet class="nav-cta">Join</Button>

    <button
      type="button"
      class="nav-burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
      id="nav-burger"
    >
      <span></span><span></span>
    </button>
  </div>
</div>

<!-- Mobile drawer -->
<div class="nav-drawer" id="nav-drawer" aria-hidden="true">
  <div class="nav-drawer-scrim" data-drawer-close></div>
  <aside class="nav-drawer-sheet" role="dialog" aria-modal="true" aria-label="Navigatie">
    <header class="nav-drawer-head">
      <a href="/" class="nav-brand" data-drawer-close>
        <img src="/assets/icon-white.svg" alt="" width="22" height="22" />
        <span>CTF</span>
      </a>
      <button type="button" class="nav-drawer-x" aria-label="Sluiten" data-drawer-close>
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 3 L15 15 M15 3 L3 15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <nav class="nav-drawer-main" aria-label="Hoofdmenu mobiel">
      <a href="/" class="nav-drawer-link" data-drawer-close>Home</a>
      <details class="nav-drawer-group">
        <summary>Over</summary>
        <a href="/about" class="nav-drawer-sub" data-drawer-close>About — Wie we zijn</a>
        <a href="/vision" class="nav-drawer-sub" data-drawer-close>Vision — Onze missie</a>
      </details>
      <a href="/projects" class="nav-drawer-link" data-drawer-close>Projecten</a>
      <details class="nav-drawer-group">
        <summary>Voor wie?</summary>
        <a href="/founders" class="nav-drawer-sub" data-drawer-close>Tech Founders</a>
        <a href="/businesses" class="nav-drawer-sub" data-drawer-close>Bedrijven</a>
        <a href="/support" class="nav-drawer-sub" data-drawer-close>Partners</a>
      </details>
      <a href="/events" class="nav-drawer-link" data-drawer-close>Events</a>
      <a href="/contact" class="nav-drawer-link" data-drawer-close>Contact</a>
    </nav>

    <a href="/apply" class="nav-drawer-cta" data-drawer-close>
      <span class="dot"></span>
      Join CTF
    </a>
  </aside>
</div>

<script>
  function wireNav() {
    const burger = document.getElementById('nav-burger');
    const drawer = document.getElementById('nav-drawer');
    if (!burger || !drawer) return;

    const open = () => {
      drawer.classList.add('open');
      drawer.setAttribute('aria-hidden', 'false');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      drawer.classList.remove('open');
      drawer.setAttribute('aria-hidden', 'true');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    burger.addEventListener('click', () =>
      drawer.classList.contains('open') ? close() : open(),
    );
    drawer.querySelectorAll<HTMLElement>('[data-drawer-close]').forEach((el) =>
      el.addEventListener('click', close),
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.classList.contains('open')) close();
    });
  }
  wireNav();
  document.addEventListener('astro:page-load', wireNav);
</script>

<style>
  .nav-cta { padding: 10px 18px 10px 10px; }
  .nav-cta .dot { width: 10px; height: 10px; flex: 0 0 10px; }

  .nav-burger {
    display: none;
    width: 38px; height: 38px;
    background: var(--ink-1);
    color: var(--ink-on-dark-1);
    border: 0; border-radius: 999px;
    cursor: pointer;
    align-items: center; justify-content: center;
    flex-direction: column; gap: 4px;
    margin-left: 4px;
  }
  .nav-burger span {
    display: block;
    width: 14px; height: 1.5px;
    background: currentColor; border-radius: 1px;
    transition: transform 220ms var(--easing);
  }

  /* Drawer */
  .nav-drawer {
    position: fixed; inset: 0;
    z-index: 200;
    pointer-events: none;
  }
  .nav-drawer.open { pointer-events: auto; }
  .nav-drawer-scrim {
    position: absolute; inset: 0;
    background: rgba(30,30,30,0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    transition: opacity 320ms var(--easing);
  }
  .nav-drawer.open .nav-drawer-scrim { opacity: 1; }
  .nav-drawer-sheet {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(420px, 88vw);
    background: var(--ink-1);
    color: var(--ink-on-dark-1);
    transform: translateX(100%);
    transition: transform 380ms var(--easing-out);
    padding: 24px 28px 32px;
    display: flex; flex-direction: column;
    box-shadow: -30px 0 60px rgba(0,0,0,0.4);
  }
  .nav-drawer.open .nav-drawer-sheet { transform: translateX(0); }

  .nav-drawer-head {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .nav-drawer-head .nav-brand { color: var(--ink-on-dark-1); }
  .nav-drawer-x {
    background: transparent; border: 0; cursor: pointer;
    color: var(--ink-on-dark-2);
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px;
    transition: background 200ms;
  }
  .nav-drawer-x:hover { background: rgba(255,255,255,0.06); }

  .nav-drawer-main {
    flex: 1;
    margin-top: 28px;
    display: flex; flex-direction: column; gap: 4px;
    overflow-y: auto;
  }
  .nav-drawer-link,
  .nav-drawer-group summary {
    display: block;
    padding: 14px 0;
    font-family: var(--font-display);
    font-size: 28px; font-weight: 400;
    letter-spacing: -0.02em; line-height: 1.2;
    color: var(--ink-on-dark-1);
    text-decoration: none;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    list-style: none;
    transition: color 180ms;
  }
  .nav-drawer-link:hover,
  .nav-drawer-group summary:hover { color: var(--ctf-blue-hover); }
  .nav-drawer-group summary::-webkit-details-marker { display: none; }
  .nav-drawer-group summary::after {
    content: '+';
    float: right;
    font-family: var(--font-display);
    color: var(--ctf-blue);
    transition: transform 220ms var(--easing);
  }
  .nav-drawer-group[open] summary::after { transform: rotate(45deg); }
  .nav-drawer-sub {
    display: block;
    padding: 10px 0 10px 12px;
    font: var(--t-body); color: var(--ink-on-dark-2);
    text-decoration: none;
    border-left: 1px solid rgba(255,255,255,0.08);
    margin-left: 4px;
    transition: color 180ms, border-color 180ms;
  }
  .nav-drawer-sub:hover { color: var(--ink-on-dark-1); border-left-color: var(--ctf-blue); }

  .nav-drawer-cta {
    margin-top: 24px;
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    padding: 16px 22px;
    background: var(--ink-on-dark-1);
    color: var(--ink-1);
    border-radius: var(--r-pill);
    font: var(--t-button);
    letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none;
    transition: background 220ms;
  }
  .nav-drawer-cta:hover { background: #fff; }
  .nav-drawer-cta .dot {
    width: 8px; height: 8px; border-radius: 999px; background: var(--ctf-blue);
  }

  @media (max-width: 800px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .nav-burger { display: inline-flex; }
    .nav-pill { padding: 6px 6px 6px 16px; gap: 10px; }
    .nav-shell { top: 12px; }
  }
</style>
